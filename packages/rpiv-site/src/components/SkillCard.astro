---
import type { SkillEntry } from "../lib/skills";

interface Props {
	skill: SkillEntry;
	variant?: "detail" | "compact";
	index?: number;
	artifactSite?: string;
}

const { skill, variant = "detail", index, artifactSite } = Astro.props;
const {
	name,
	description,
	"argument-hint": argHint,
	"disable-model-invocation": disableInvoke,
} = skill.data;
---

<article class:list={["card", "skill", `skill--${variant}`]}>
	<header class="skill__head">
		{index !== undefined && (
			<span class="skill__index mono">{String(index).padStart(2, "0")}</span>
		)}
		<span class="chip chip--sage skill__name">/skill:{name}</span>
		{disableInvoke && <span class="chip chip--ochre">manual only</span>}
	</header>

	<p class="skill__desc">{description}</p>

	{(argHint || artifactSite) && (
		<footer class="skill__foot">
			{argHint && (
				<p class="mono skill__hint">
					<span class="skill__label">arg</span>{argHint}
				</p>
			)}
			{artifactSite && (
				<p class="mono skill__hint">
					<span class="skill__label">→</span>{artifactSite}
				</p>
			)}
		</footer>
	)}
</article>

<style>
	.skill { display: flex; flex-direction: column; gap: var(--space-3); }
	.skill__head {
		display: flex; flex-wrap: wrap; align-items: center;
		gap: var(--space-3);
		margin-bottom: var(--space-2);
		position: relative; z-index: 1;
	}
	.skill__index {
		color: var(--text-distant);
		font-size: var(--type-tiny);
		letter-spacing: 0.18em;
	}
	.skill__desc {
		color: var(--text);
		font-family: var(--font-serif);
		max-width: none;
		margin: 0;
		position: relative; z-index: 1;
	}
	.skill--compact .skill__desc { font-size: var(--type-small); }
	.skill__foot {
		display: flex; flex-direction: column;
		gap: var(--space-2);
		margin-top: var(--space-3);
		padding-top: var(--space-3);
		border-top: 1px solid var(--rule);
		position: relative; z-index: 1;
	}
	.skill__hint {
		font-size: var(--type-small);
		color: var(--text-quiet);
		margin: 0;
	}
	.skill__label {
		display: inline-block;
		min-width: 28px;
		color: var(--text-distant);
		margin-right: var(--space-2);
	}
</style>
